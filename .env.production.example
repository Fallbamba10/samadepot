# Copie ce fichier en .env.production et remplis les valeurs
# Puis ajoute chaque variable dans Vercel → Settings → Environment Variables

# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://ton-projet.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Storage ─────────────────────────────────────────────────────────────────
SUPABASE_STORAGE_BUCKET=submissions
SUPABASE_STORAGE_BUCKET_RECEIPTS=receipts

# ─── App ─────────────────────────────────────────────────────────────────────
# URL publique de l'app (sans slash final)
NEXT_PUBLIC_SITE_URL=https://samadepot.vercel.app

