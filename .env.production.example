# Copie ce fichier en .env.production et remplis les valeurs
# Puis ajoute chaque variable dans Vercel → Settings → Environment Variables

# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://ton-projet.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Storage ─────────────────────────────────────────────────────────────────
SUPABASE_STORAGE_BUCKET=submissions
SUPABASE_STORAGE_BUCKET_RECEIPTS=receipts

# ─── App ─────────────────────────────────────────────────────────────────────
# URL publique de l'app (sans slash final) — OBLIGATOIRE pour les callbacks PayTech
NEXT_PUBLIC_SITE_URL=https://samadepot.vercel.app

# ─── PayTech ─────────────────────────────────────────────────────────────────
# Clés disponibles sur https://paytech.sn → Mon compte → API
PAYTECH_API_KEY=
PAYTECH_API_SECRET=

# ─── Cron ────────────────────────────────────────────────────────────────────
# Secret pour sécuriser les routes /api/cron/* (Vercel Cron l'envoie automatiquement)
# Génère une valeur aléatoire : openssl rand -hex 32
CRON_SECRET=

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Clé API Resend pour les emails transactionnels
RESEND_API_KEY=
EMAIL_FROM=noreply@samadepot.app

